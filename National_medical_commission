<script>
 var fontSize = 100;
var increaseCount = 0;
var decreaseCount = 0;
var MAX_CLICKS = 3;

function set_font_size(fontType) {

  if (fontType === "increase") {
    if (increaseCount < MAX_CLICKS) {
      fontSize += 2;
      increaseCount++;
      decreaseCount = 0; // reset opposite
    }
  } 
  else if (fontType === "decrease") {
    if (decreaseCount < MAX_CLICKS) {
      fontSize -= 10;
      decreaseCount++;
      increaseCount = 0; // reset opposite
    }
  } 
  else {
    fontSize = 100;
    increaseCount = 0;
    decreaseCount = 0;
  }

  jQuery("#page").css("font-size", fontSize + "%");
  jQuery("#main").css("font-size", fontSize + "%");
